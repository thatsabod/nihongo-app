rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Community post images: anyone can view; only the owner can upload to their
    // own folder, images only, max 5 MB.
    match /communityImages/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Admin media library uploads. Public read (URLs are referenced in content);
    // authenticated image writes under 5 MB. Storage rules cannot read the
    // Firestore role, so admin gating is enforced by the admin-only UI + the
    // admin-only `mediaLibrary` Firestore metadata; orphan blobs carry no
    // metadata and are not surfaced. (Documented in ADMIN_REMAINING_MODULES_REPORT.)
    match /adminMedia/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
