rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner'
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userUsername == 'abdol'
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username == 'abdol'
        );
    }

    function isParticipant(a, b) {
      return signedIn() && (request.auth.uid == a || request.auth.uid == b);
    }

    function canManageBroadcasts() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          isAdmin()
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator'
        );
    }

    match /users/{userId} {
      // Owner reads own doc; admins (User Management) can read any user.
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && !('role' in request.resource.data);
      // Owner may update their own doc EXCEPT role/ban fields; admins may update
      // any user (grant XP/gems, change level/role, ban/suspend).
      allow update: if isAdmin()
        || (isOwner(userId)
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'banned', 'suspendedUntil']));
      allow delete: if isOwner(userId);
    }

    match /usernames/{username} {
      allow read: if true;
      allow create, update, delete: if signedIn() && request.resource.data.uid == request.auth.uid;
    }

    match /publicProfiles/{userId} {
      allow read: if true;
      allow create, update: if signedIn();
      allow delete: if isOwner(userId);
    }

    match /friendRequests/{requestId} {
      allow read: if signedIn()
        && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.fromId == request.auth.uid;
      allow update, delete: if signedIn()
        && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
    }

    match /follows/{followId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && (request.resource.data.followerId == request.auth.uid
          || request.resource.data.followingId == request.auth.uid);
      allow delete: if signedIn()
        && (resource.data.followerId == request.auth.uid
          || resource.data.followingId == request.auth.uid);
    }

    match /messages/{messageId} {
      allow read: if signedIn()
        && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.fromId == request.auth.uid;
      allow update, delete: if signedIn()
        && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow read: if signedIn()
        && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.fromId == request.auth.uid;
      allow update, delete: if signedIn()
        && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
    }

    match /communityQuestions/{questionId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /communityQuestionReplies/{replyId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /communityQuestionLikes/{likeId} {
      allow read: if true;
      allow create, update: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /communityQuestionReposts/{repostId} {
      allow read: if true;
      allow create, update: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /communityPollVotes/{voteId} {
      allow read: if true;
      allow create, update: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /communityReports/{reportId} {
      allow create: if signedIn() && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if false;
    }

    match /studyGroupJoins/{joinId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /lessonOverrides/{lessonId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // CMS / Control Center config (app name, feature flags, nav, AI prompts…).
    // World-readable so the app loads it; admin-only writes.
    match /config/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Stories CMS — admin-authored / edited stories. Public read (learners),
    // admin-only write.
    match /storyOverrides/{storyId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Vocabulary & Grammar CMS — public read (feeds app), admin-only write.
    match /vocab/{vocabId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /grammar/{grammarId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Notifications — admin broadcasts. Public read (learners), admin-only write.
    match /broadcasts/{broadcastId} {
      allow read: if true;
      allow create, update, delete: if canManageBroadcasts();
    }

    match /adminLogs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /callSessions/{sessionId} {
      allow read: if signedIn() && request.auth.uid == resource.data.uid;
      allow create: if signedIn() && request.auth.uid == request.resource.data.uid;
      allow update, delete: if signedIn() && request.auth.uid == resource.data.uid;
    }
  }
}
